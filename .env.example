# Trade Nexus CLI — Environment Variables
# Copy to .env and fill in your values.

# Required: Your Google Gemini API key
GEMINI_API_KEY=AIzaSyAOO09uocO2PopDVtUuvgQG2LAwHONOZ-Y

# Optional: Override the default model for generation tasks
GEMINI_DEFAULT_MODEL=gemma-4-31b-it

# Optional: Override the model used for grounding (Google Search) tasks
GEMINI_GROUNDING_MODEL=gemma-4-31b-it

# Optional: Thinking budget (0 = disabled, -1 = dynamic, N = token budget)
GEMINI_THINKING_BUDGET=0
